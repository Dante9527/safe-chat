# ============================================================================
# SafeChat — 環境設定（唯一權威來源）
# ============================================================================
# 使用方式：複製為 .env 後依需求修改
#   cp .env.example .env
#
# 程式碼透過 os.getenv() 直接讀取這些變數，不經過中間層。
# ============================================================================


# ──────────────────────────────────────────────────────────────────────────────
# LLM 推論後端（Ollama）
# ──────────────────────────────────────────────────────────────────────────────

# Ollama 模型名稱（需先用 ollama pull 下載）
#   預設：llama3.1:8b（Meta，8B，~8GB RAM，32GB 機器實測最佳）
#   備選：gemma4:26b（Google，26B MoE，需 64GB+ RAM，32GB 會 OOM）
OLLAMA_MODEL=llama3.1:8b

# Ollama 服務位址
#   本機開發：http://localhost:11434
#   Docker 容器連 host Ollama：http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434

# KV-cache 大小（tokens）
#   KV-cache 是 LLM 推論時的記憶體快取，存放已處理 token 的 Key/Value 向量，
#   避免每生成一個新 token 都要重算前面所有 token。
#   llama3.1:8b 原生支援 128K，設 4096 可容納章節擴展上限（8 條 × 500 字元 ≈ 1333 tokens）
#   加上回答空間（~500 tokens）。設太大會浪費 RAM 且拖慢首次載入。
OLLAMA_NUM_CTX=4096

# LLM 生成溫度（0.0–1.0）
#   控制回答的隨機性：越低越確定（適合法規查詢），越高越有創意。
#   工安場景建議 0.1，確保回答忠於法規原文，不會「發揮」。
LLM_TEMPERATURE=0.1


# ──────────────────────────────────────────────────────────────────────────────
# RAG 檢索與生成
# ──────────────────────────────────────────────────────────────────────────────

# 每次檢索回傳的文本區塊（chunk）數量
#   這是「伺服器預設值」，前端可透過 API 參數 top_k 單次覆寫（範圍 1-10）。
#   5 = 平衡品質與速度（推薦）
#   3 = 更快但可能漏條文
#   8 = 最完整但較慢
RAG_TOP_K=5

# 注入 LLM prompt 的每個 chunk 最大字元數
#   法規條文切分後每條完整保留，此值控制注入 prompt 時的截斷上限。
#   500 字元 ≈ 167 tokens（中文約 3 字元/token）。
RAG_PROMPT_CHUNK_CHARS=500

# 章節擴展時帶入的最大條文數量
#   當 top_k 結果中有 2+ 筆來自同一章節時，自動擴展帶入該章條文。
#   此值限制擴展上限，避免 prompt 過大拖慢回應並稀釋相關性。
#   8 = 平衡速度與完整度（8 × 500 字元 ≈ 1333 tokens）
#   0 或不設定 = 預設 8
MAX_CHAPTER_ARTICLES=8

# Embedding 模型（完全本地，不需 API Key）
#   用於將文件與查詢轉為向量，進行語意相似度比對。
#   intfloat/multilingual-e5-large-instruct：Microsoft 開源多語言模型，1024 維，
#   中文檢索品質優於 e5-base 約 9%（MIRACL nDCG@10: 56.2 vs 51.5）。
EMBEDDING_MODEL=intfloat/multilingual-e5-large-instruct


# ──────────────────────────────────────────────────────────────────────────────
# 伺服器
# ──────────────────────────────────────────────────────────────────────────────

# 監聽位址
#   本機開發用 127.0.0.1（僅本機可連）
#   Docker 容器內由 Dockerfile CMD 強制綁 0.0.0.0（容器網路需求）
HOST=127.0.0.1
PORT=8000


# ──────────────────────────────────────────────────────────────────────────────
# 安全設定
# ──────────────────────────────────────────────────────────────────────────────

# 管理員 token — 清空知識庫（DELETE /api/reset）時需提供此 token
#   留空 = 停用清空功能（任何人都無法清空）
#   部署前請設定強隨機字串：openssl rand -hex 16
ADMIN_TOKEN=

# 檔案上傳大小上限（MB）
MAX_UPLOAD_MB=20

# CORS 允許的跨來源請求（逗號分隔）
#   留空 = 僅允許同源請求（前端由 FastAPI 自己提供，不需 CORS）
CORS_ORIGINS=

# 速率限制 — 每個 IP 的請求頻率上限（slowapi 格式）
RATE_LIMIT=30/minute


# ============================================================================
# 部署前置條件
# ============================================================================
# Ollama 需安裝在 host 上（利用 Metal GPU 加速推論）：
#   brew install ollama
#   brew services start ollama
#   ollama pull llama3.1:8b
#
# Docker 部署時，將 OLLAMA_BASE_URL 改為 http://host.docker.internal:11434
# ============================================================================
